# --- Garmin Connect ---
# Your Garmin Connect login email. Password & MFA are entered interactively
# on first run (never stored in this file). The auth token is then cached.
GARMIN_EMAIL=you@example.com

# Where the cached Garmin auth token lives (so we don't re-login every run,
# which is what triggers rate-limit lockouts). Default is fine.
GARMIN_TOKEN_STORE=~/.garminconnect

# --- LLM provider (the coach brain) ---
# ollama = free, local, private (default).  claude = paid, sharper advice.
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Only needed if LLM_PROVIDER=claude:
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# --- Sync ---
# How many days of history to backfill on first sync.
INITIAL_BACKFILL_DAYS=90
# Auto-sync times (24h, comma-separated hours). e.g. 7 = 7am, 19 = 7pm
AUTO_SYNC_HOURS=7,19

# --- App ---
HOST=0.0.0.0
PORT=8000
# SQLite DB file (relative to project root unless absolute).
DB_PATH=garmincoach.db
# App login (protects the whole UI with a cookie-based session).
# Leave blank to disable app-level auth.
APP_USERNAME=
APP_PASSWORD=
# Secret for signing session cookies. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-string
# How many days the login cookie persists (default 30).
# SESSION_MAX_AGE_DAYS=30
